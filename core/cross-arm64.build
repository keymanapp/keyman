[host_machine]
system = 'windows'
subsystem = 'windows'
cpu_family = 'aarch64'
cpu = 'arm64'
endian = 'little'

[binaries]
c = 'cl'
cpp = 'cl'
ar = 'lib'
ld = 'link'
strip = 'llvm-strip'   # optional; MSVC doesn’t have a native strip
pkgconfig = 'pkg-config'  # optional; used only if you have pkg-config installed
